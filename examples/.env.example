# Descope Configuration
#
# Paste the full OAuth issuer URL of your Descope MCP server / Inbound App.
# You can find it on the app's settings page in the Descope Console.
#
# Supported formats:
#   - Inbound App:  https://api.descope.com/v1/apps/<projectId>
#   - Agentic/MCP:  https://api.descope.com/v1/apps/agentic/<projectId>/<mcpServerId>
DESCOPE_MCP_SERVER_ISSUER=https://api.descope.com/v1/apps/agentic/your_project_id_here/your_mcp_server_id_here

# Optional: Project ID (auto-derived from DESCOPE_MCP_SERVER_ISSUER when unset)
# DESCOPE_PROJECT_ID=your_project_id_here

# Server Configuration
# The URL where your MCP server will be accessible
SERVER_URL=http://localhost:3000

# Optional: Custom Descope Base URL (auto-derived from the issuer URL when unset)
# DESCOPE_BASE_URL=https://api.descope.com

# Optional: Management Key - only needed as a fallback for legacy outbound token
# exchange or if you enable the management-key-backed Authorization Server
# endpoints. The MCP server access token is now used to exchange for outbound
# app tokens by default, so this is typically not required.
# Get this from: https://app.descope.com/settings/company/managementkeys
# DESCOPE_MANAGEMENT_KEY=your_management_key_here

# Optional: Enable Authorization Server endpoints (/authorize, /register)
# Default is false (Resource Server mode only)
# ENABLE_AUTH_SERVER=false

# Optional: Server port (default is 3000)
# PORT=3000

# Optional: Node.js environment
# NODE_ENV=development